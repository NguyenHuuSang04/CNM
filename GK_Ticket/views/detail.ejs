<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Chi tiet ve</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
</head>

<body class="bg-light">
    <main class="container py-4" style="max-width: 980px;">
        <header class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h3 mb-0">Chi tiet ve</h1>
            <div class="d-flex gap-2">
                <a href="/tickets" class="btn btn-outline-secondary">Danh sach</a>
                <a href="/tickets/<%= ticket.ticketId %>/edit" class="btn btn-primary">Sua</a>
            </div>
        </header>

        <section class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="row g-4 align-items-start">
                    <div class="col-md-7">
                        <p><strong>ticketId:</strong>
                            <%= ticket.ticketId || '-' %>
                        </p>
                        <p><strong>eventName:</strong>
                            <%= ticket.eventName || '-' %>
                        </p>
                        <p><strong>holderName:</strong>
                            <%= ticket.holderName || '-' %>
                        </p>
                        <p><strong>category:</strong>
                            <%= ticket.category || '-' %>
                        </p>
                        <p><strong>quantity:</strong>
                            <%= ticket.quantity || 0 %>
                        </p>
                        <p><strong>pricePerTicket:</strong>
                            <%= Number(ticket.pricePerTicket || 0).toLocaleString("vi-VN") %> VND
                        </p>
                        <p><strong>eventDate:</strong>
                            <%= ticket.eventDate || '-' %>
                        </p>
                        <p><strong>status:</strong>
                            <%= ticket.status || '-' %>
                        </p>
                        <p><strong>imageUrl:</strong>
                            <%= ticket.imageUrl || '-' %>
                        </p>
                        <p><strong>createdAt:</strong>
                            <%= ticket.createdAt || '-' %>
                        </p>
                        <hr />
                        <p><strong>totalAmount:</strong>
                            <%= Number(ticket.totalAmount || 0).toLocaleString("vi-VN") %> VND
                        </p>
                        <p><strong>finalAmount:</strong>
                            <%= Number(ticket.finalAmount || 0).toLocaleString("vi-VN") %> VND
                        </p>
                        <p>
                            <strong>Ket qua nghiep vu:</strong>
                            <%= ticket.discountApplied ? 'Duoc giam gia' : 'Khong giam gia' %>
                        </p>
                        <p><strong>Quyen loi:</strong>
                            <%= Array.isArray(ticket.addOns) && ticket.addOns.length ? ticket.addOns.join(', ') : ' -'
                                %>
                        </p>
                    </div>
                    <div class="col-md-5">
                        <% if (ticket.imageUrl) { %>
                            <img src="<%= ticket.imageUrl %>" alt="ticket-image" class="img-fluid rounded border" />
                            <% } else { %>
                                <p class="text-secondary">Khong co anh cho ve nay.</p>
                                <% } %>
                    </div>
                </div>
            </div>
        </section>
    </main>
</body>

</html>