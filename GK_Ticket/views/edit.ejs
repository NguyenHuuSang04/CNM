<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cap nhat ve</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
</head>

<body class="bg-light">
    <main class="container py-4" style="max-width: 920px;">
        <header class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h3 mb-0">Cap nhat ve</h1>
            <a href="/tickets" class="btn btn-outline-secondary">Quay lai</a>
        </header>

        <% const categories=(formMeta && formMeta.categories) || []; %>
            <% const statuses=(formMeta && formMeta.statuses) || []; %>
                <% const addOnOptions=(formMeta && formMeta.addOnOptions) || []; %>

                    <% if (Array.isArray(errors) && errors.length> 0) { %>
                        <div class="alert alert-danger">
                            <ul class="mb-0">
                                <% errors.forEach(function(item) { %>
                                    <li>
                                        <%= item %>
                                    </li>
                                    <% }) %>
                            </ul>
                        </div>
                        <% } %>

                            <section class="card border-0 shadow-sm">
                                <div class="card-body">
                                    <form action="/tickets/<%= ticket.ticketId %>/update" method="POST"
                                        enctype="multipart/form-data" class="row g-3">
                                        <div class="col-md-6">
                                            <label class="form-label">Ten su kien</label>
                                            <input type="text" name="eventName" class="form-control"
                                                value="<%= ticket.eventName || '' %>" required />
                                        </div>

                                        <div class="col-md-6">
                                            <label class="form-label">Ten nguoi so huu</label>
                                            <input type="text" name="holderName" class="form-control"
                                                value="<%= ticket.holderName || '' %>" required />
                                        </div>

                                        <div class="col-12">
                                            <label class="form-label d-block">Category (radio - chon 1)</label>
                                            <% categories.forEach(function(item) { %>
                                                <label class="form-check form-check-inline">
                                                    <input class="form-check-input" type="radio" name="category"
                                                        value="<%= item %>" <%=(ticket.category || 'Standard' )===item
                                                        ? 'checked' : '' %> />
                                                    <span class="form-check-label">
                                                        <%= item %>
                                                    </span>
                                                </label>
                                                <% }) %>
                                        </div>

                                        <div class="col-md-6">
                                            <label class="form-label">So luong</label>
                                            <input type="number" min="1" step="1" name="quantity" class="form-control"
                                                value="<%= ticket.quantity || '' %>" required />
                                        </div>

                                        <div class="col-md-6">
                                            <label class="form-label">Gia moi ve</label>
                                            <input type="number" min="1" step="1000" name="pricePerTicket"
                                                class="form-control" value="<%= ticket.pricePerTicket || '' %>"
                                                required />
                                        </div>

                                        <div class="col-md-6">
                                            <label class="form-label">Ngay su kien</label>
                                            <input type="date" name="eventDate" class="form-control"
                                                value="<%= ticket.eventDate || '' %>" required />
                                        </div>

                                        <div class="col-md-6">
                                            <label class="form-label">Status (select - chon 1)</label>
                                            <select name="status" class="form-select" required>
                                                <% statuses.forEach(function(item) { %>
                                                    <option value="<%= item %>" <%=(ticket.status || 'Upcoming' )===item
                                                        ? 'selected' : '' %>><%= item %>
                                                    </option>
                                                    <% }) %>
                                            </select>
                                        </div>

                                        <div class="col-12">
                                            <label class="form-label d-block">Quyen loi kem theo (checkbox - chon
                                                nhieu)</label>
                                            <% addOnOptions.forEach(function(item) { %>
                                                <label class="form-check form-check-inline">
                                                    <input class="form-check-input" type="checkbox" name="addOns"
                                                        value="<%= item %>" <%=(ticket.addOns || []).includes(item)
                                                        ? 'checked' : '' %> />
                                                    <span class="form-check-label">
                                                        <%= item %>
                                                    </span>
                                                </label>
                                                <% }) %>
                                        </div>

                                        <div class="col-md-6">
                                            <label class="form-label">Anh moi (khong bat buoc)</label>
                                            <input type="file" name="image" class="form-control" accept="image/*" />
                                        </div>

                                        <div class="col-md-6">
                                            <label class="form-label d-block">Anh hien tai</label>
                                            <% if (ticket.imageUrl) { %>
                                                <img src="<%= ticket.imageUrl %>" alt="current-image"
                                                    class="rounded border"
                                                    style="width: 96px; height: 96px; object-fit: cover;" />
                                                <% } else { %>
                                                    <span class="text-secondary">Khong co anh</span>
                                                    <% } %>
                                        </div>

                                        <div class="col-12 d-flex gap-2">
                                            <button type="submit" class="btn btn-primary">Cap nhat</button>
                                            <button type="reset" class="btn btn-outline-secondary">Lam moi</button>
                                            <a href="/tickets/<%= ticket.ticketId %>" class="btn btn-outline-dark">Chi
                                                tiet</a>
                                        </div>
                                    </form>
                                </div>
                            </section>
    </main>
</body>

</html>