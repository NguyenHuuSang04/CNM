<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Them mon hoc</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
</head>

<body class="bg-light">
    <main class="container py-4" style="max-width: 760px;">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h3 mb-0">Them mon hoc</h1>
            <a href="/subjects" class="btn btn-outline-secondary">Quay lai danh sach</a>
        </div>

        <% const values=oldData || {}; %>
            <% const deliveryOptions=(formOptions && formOptions.deliveryOptions) || []; %>
                <% const creditOptions=(formOptions && formOptions.creditOptions) || []; %>
                    <% const featureOptions=(formOptions && formOptions.featureOptions) || []; %>

                        <% if (Array.isArray(errors) && errors.length> 0) { %>
                            <div class="alert alert-danger" role="alert">
                                <ul class="mb-0">
                                    <% errors.forEach(function(item) { %>
                                        <li>
                                            <%= item %>
                                        </li>
                                        <% }) %>
                                </ul>
                            </div>
                            <% } %>

                                <section class="card border-0 shadow-sm">
                                    <div class="card-body">
                                        <form action="/subjects/create" method="POST" enctype="multipart/form-data">
                                            <div class="mb-3">
                                                <label for="name" class="form-label">Ten mon hoc</label>
                                                <input id="name" name="name" class="form-control"
                                                    value="<%= values.name || '' %>" required />

                                            </div>

                                            <div class="mb-3">
                                                <label for="type" class="form-label">Loai mon hoc</label>
                                                <input id="type" name="type" class="form-control"
                                                    value="<%= values.type || '' %>" required />
                                            </div>

                                            <div class="mb-3">
                                                <label for="semester" class="form-label">Hoc ky (1-12)</label>
                                                <input id="semester" name="semester" type="number" min="1" max="12"
                                                    class="form-control" value="<%= values.semester || '' %>"
                                                    required />
                                            </div>

                                            <div class="mb-3">
                                                <label for="faculty" class="form-label">Khoa</label>
                                                <input id="faculty" name="faculty" class="form-control"
                                                    value="<%= values.faculty || '' %>" required />
                                            </div>

                                            <div class="mb-3">
                                                <label class="form-label d-block">Hinh thuc hoc</label>
                                                <% deliveryOptions.forEach(function(option) { %>
                                                    <div class="form-check form-check-inline">
                                                        <input id="delivery-<%= option %>" name="delivery" type="radio"
                                                            class="form-check-input" value="<%= option %>"
                                                            <%=(values.delivery || 'offline' )===option ? 'checked' : ''
                                                            %> />
                                                        <label for="delivery-<%= option %>"
                                                            class="form-check-label text-capitalize">
                                                            <%= option %>
                                                        </label>
                                                    </div>
                                                    <% }) %>
                                            </div>

                                            <div class="mb-3">
                                                <label for="credits" class="form-label">So tin chi</label>
                                                <select id="credits" name="credits" class="form-select" required>
                                                    <% creditOptions.forEach(function(option) { %>
                                                        <option value="<%= option %>" <%=String(values.credits || '3'
                                                            )===String(option) ? 'selected' : '' %>>
                                                            <%= option %> tin chi
                                                        </option>
                                                        <% }) %>
                                                </select>
                                            </div>

                                            <div class="mb-3">
                                                <label class="form-label d-block">Tien ich mon hoc</label>
                                                <% featureOptions.forEach(function(option) { %>
                                                    <div class="form-check">
                                                        <input id="feature-<%= option %>" name="features"
                                                            type="checkbox" class="form-check-input"
                                                            value="<%= option %>" <%=(values.features ||
                                                            []).includes(option) ? 'checked' : '' %> />
                                                        <label for="feature-<%= option %>"
                                                            class="form-check-label text-capitalize">
                                                            <%= option %>
                                                        </label>
                                                    </div>
                                                    <% }) %>
                                            </div>

                                            <div class="mb-4">
                                                <label for="image" class="form-label">Hinh anh</label>
                                                <input id="image" name="image" type="file" class="form-control"
                                                    accept="image/*" required />
                                            </div>

                                            <div class="d-flex gap-2">
                                                <button type="submit" class="btn btn-primary">Luu mon hoc</button>
                                                <button type="reset" class="btn btn-outline-secondary">Lam moi</button>
                                            </div>
                                        </form>
                                    </div>
                                </section>
    </main>
</body>

</html>