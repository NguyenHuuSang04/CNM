<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Danh sach mon hoc</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
</head>

<body class="bg-light" data-alert-message="<%= alertMessage || '' %>">
    <main class="container py-4">
        <header class="mb-3">
            <h1 class="h3 mb-1">Danh sach mon hoc</h1>
            <p class="text-secondary mb-0">Giao dien tong hop cac mon hoc hien co.</p>
        </header>
        <div class="d-flex flex-column flex-md-row gap-2 justify-content-between mb-3">
            <a href="/subjects/create" class="btn btn-primary">Them mon hoc</a>
            <form action="/subjects" method="GET" class="d-flex" role="search">
                <input type="text" name="q" class="form-control me-2" placeholder="Tim theo ten mon"
                    value="<%= q || '' %>" />
                <button type="submit" class="btn btn-outline-primary">Tim</button>
            </form>
        </div>



        <section class="card shadow-sm border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-primary">
                            <tr>
                                <th>Ten mon</th>
                                <th>Loai</th>
                                <th>Hoc ky</th>
                                <th>Khoa</th>
                                <th>Hinh thuc</th>
                                <th>Tin chi</th>
                                <th>Tien ich</th>
                                <th>Hinh anh</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (subjects.length===0) { %>
                                <tr>
                                    <td colspan="9" class="text-center text-secondary py-4">Chua co du lieu mon hoc.
                                    </td>
                                </tr>
                                <% } else { %>
                                    <% subjects.forEach(function(subject) { %>
                                        <tr>
                                            <td>
                                                <%= subject.name || "-" %>
                                            </td>
                                            <td>
                                                <%= subject.type || "-" %>
                                            </td>
                                            <td>
                                                <%= subject.semester || "-" %>
                                            </td>
                                            <td>
                                                <%= subject.faculty || "-" %>
                                            </td>
                                            <td class="text-capitalize">
                                                <%= subject.delivery || "-" %>
                                            </td>
                                            <td>
                                                <%= subject.credits ? subject.credits + ' TC' : '-' %>
                                            </td>
                                            <td>
                                                <%= Array.isArray(subject.features) && subject.features.length ?
                                                    subject.features.join(', ') : ' -' %>
                                            </td>
                                            <td>
                                                <% if (subject.image) { %>
                                                    <img src="<%= subject.image %>" alt="subject-image"
                                                        class="rounded border"
                                                        style="width: 72px; height: 72px; object-fit: cover;" />
                                                    <% } else { %>
                                                        <span class="text-secondary">Khong co</span>
                                                        <% } %>
                                            </td>
                                            <td>
                                                <div class="d-flex gap-2">
                                                    <a href="/subjects/<%= subject.id %>"
                                                        class="btn btn-sm btn-outline-secondary">Edit</a>
                                                    <form action="/subjects/<%= subject.id %>/delete" method="POST"
                                                        onsubmit="return confirm('Ban chac chan muon xoa mon hoc nay?');">
                                                        <input type="hidden" name="name" value="<%= subject.name %>" />
                                                        <button type="submit"
                                                            class="btn btn-sm btn-outline-danger">Delete</button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                        <% }) %>
                                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    </main>

    <script>
        (function () {
            var message = document.body.dataset.alertMessage || "";
            if (!message) {
                return;
            }

            window.alert(message);

            var url = new URL(window.location.href);
            url.searchParams.delete("msg");
            window.history.replaceState({}, "", url.toString());
        })();
    </script>
</body>

</html>