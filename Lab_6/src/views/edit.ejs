<%- include('partials/header') %>

    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/products">Danh Sách Sản Phẩm</a></li>
            <li class="breadcrumb-item active">Sửa Sản Phẩm</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-warning text-dark py-3">
                    <h5 class="mb-0">
                        <i class="bi bi-pencil-square me-2"></i>Sửa Sản Phẩm
                    </h5>
                </div>
                <div class="card-body p-4">

                    <% if (error) { %>
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-circle-fill me-2"></i>
                            <%= error %>
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                        <% } %>

                            <form action="/products/edit/<%= product.id %>" method="POST" enctype="multipart/form-data" id="editForm" novalidate>

                                <!-- ID (read-only) -->
                                <div class="mb-3">
                                    <label class="form-label fw-medium">Mã Sản Phẩm</label>
                                    <input type="text" class="form-control bg-light" value="<%= product.id %>" readonly>
                                    <div class="form-text">Mã sản phẩm không thể thay đổi.</div>
                                </div>

                                <!-- Name -->
                                <div class="mb-3">
                                    <label for="name" class="form-label fw-medium">
              Tên Sản Phẩm <span class="text-danger">*</span>
            </label>
                                    <input type="text" class="form-control" id="name" name="name" value="<%= product.name %>" required>
                                    <div class="invalid-feedback">Vui lòng nhập tên sản phẩm.</div>
                                </div>

                                <!-- Current image -->
                                <div class="mb-2">
                                    <label class="form-label fw-medium">Hình Ảnh Hiện Tại</label>
                                    <div>
                                        <img src="<%= product.image || '/images/default-product.svg' %>" alt="<%= product.name %>" id="currentImg" class="img-preview" onerror="this.src='/images/default-product.svg'">
                                    </div>
                                </div>

                                <!-- New image (optional) -->
                                <div class="mb-3">
                                    <label for="image" class="form-label fw-medium">Thay Hình Ảnh Mới</label>
                                    <input type="file" class="form-control" id="image" name="image" accept="image/jpeg,image/jpg,image/png,image/gif,image/webp">
                                    <div class="form-text">
                                        <i class="bi bi-info-circle me-1"></i> Để trống nếu muốn giữ hình hiện tại. JPG, PNG, GIF, WEBP — tối đa 5&nbsp;MB.
                                    </div>
                                    <div id="newImgBox" class="mt-2 d-none">
                                        <p class="form-text mb-1">Xem trước ảnh mới:</p>
                                        <img id="newImgPreview" src="" alt="Preview" class="img-preview">
                                    </div>
                                </div>

                                <!-- Price -->
                                <div class="mb-3">
                                    <label for="price" class="form-label fw-medium">
              Giá (VNĐ) <span class="text-danger">*</span>
            </label>
                                    <input type="number" class="form-control" id="price" name="price" value="<%= product.price %>" min="0.01" step="any" required>
                                    <div class="invalid-feedback">Giá phải lớn hơn 0.</div>
                                </div>

                                <!-- Quantity -->
                                <div class="mb-4">
                                    <label for="quantity" class="form-label fw-medium">
              Số Lượng <span class="text-danger">*</span>
            </label>
                                    <input type="number" class="form-control" id="quantity" name="quantity" value="<%= product.quantity %>" min="0" step="1" required>
                                    <div class="invalid-feedback">Số lượng phải ≥ 0.</div>
                                </div>

                                <div class="d-flex gap-2">
                                    <button type="submit" class="btn btn-warning flex-grow-1">
              <i class="bi bi-check-circle me-1"></i>Cập Nhật
            </button>
                                    <a href="/products" class="btn btn-outline-secondary">
                                        <i class="bi bi-arrow-left me-1"></i>Hủy
                                    </a>
                                </div>
                            </form>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Preview new image on file select
        document.getElementById('image').addEventListener('change', function() {
            const file = this.files[0];
            if (!file) {
                document.getElementById('newImgBox').classList.add('d-none');
                return;
            }
            const reader = new FileReader();
            reader.onload = (e) => {
                document.getElementById('newImgPreview').src = e.target.result;
                document.getElementById('newImgBox').classList.remove('d-none');
            };
            reader.readAsDataURL(file);
        });

        // Client-side validation
        document.getElementById('editForm').addEventListener('submit', function(e) {
            let ok = true;
            const mark = (id, valid) => {
                document.getElementById(id).classList.toggle('is-invalid', !valid);
                if (!valid) ok = false;
            };

            mark('name', !!document.getElementById('name').value.trim());
            const price = parseFloat(document.getElementById('price').value);
            mark('price', !isNaN(price) && price > 0);
            const qty = parseInt(document.getElementById('quantity').value, 10);
            mark('quantity', !isNaN(qty) && qty >= 0);

            if (!ok) e.preventDefault();
        });
    </script>

    <%- include('partials/footer') %>