<%- include('partials/header') %>

    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/products">Danh Sách Sản Phẩm</a></li>
            <li class="breadcrumb-item active">Thêm Sản Phẩm</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Thêm Sản Phẩm Mới</h5>
                </div>
                <div class="card-body p-4">

                    <% if (error) { %>
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-circle-fill me-2"></i>
                            <%= error %>
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                        <% } %>

                            <form action="/products/add" method="POST" enctype="multipart/form-data" id="addForm" novalidate>

                                <!-- Name -->
                                <div class="mb-3">
                                    <label for="name" class="form-label fw-medium">
              Tên Sản Phẩm <span class="text-danger">*</span>
            </label>
                                    <input type="text" class="form-control" id="name" name="name" placeholder="Nhập tên sản phẩm" required>
                                    <div class="invalid-feedback">Vui lòng nhập tên sản phẩm.</div>
                                </div>

                                <!-- Image -->
                                <div class="mb-3">
                                    <label for="image" class="form-label fw-medium">Hình Ảnh</label>
                                    <input type="file" class="form-control" id="image" name="image" accept="image/jpeg,image/jpg,image/png,image/gif,image/webp">
                                    <div class="form-text">
                                        <i class="bi bi-info-circle me-1"></i>Không bắt buộc — JPG, PNG, GIF, WEBP, tối đa 5&nbsp;MB. Nếu bỏ trống sẽ dùng ảnh mặc định.
                                    </div>
                                    <div id="imgPreviewBox" class="mt-2 d-none">
                                        <img id="imgPreview" src="" alt="Preview" class="img-preview">
                                    </div>
                                </div>

                                <!-- Price -->
                                <div class="mb-3">
                                    <label for="price" class="form-label fw-medium">
              Giá (VNĐ) <span class="text-danger">*</span>
            </label>
                                    <input type="number" class="form-control" id="price" name="price" placeholder="Nhập giá sản phẩm" min="0.01" step="any" required>
                                    <div class="invalid-feedback">Giá phải lớn hơn 0.</div>
                                </div>

                                <!-- Quantity -->
                                <div class="mb-4">
                                    <label for="quantity" class="form-label fw-medium">
              Số Lượng <span class="text-danger">*</span>
            </label>
                                    <input type="number" class="form-control" id="quantity" name="quantity" placeholder="Nhập số lượng" min="0" step="1" required>
                                    <div class="invalid-feedback">Số lượng phải ≥ 0.</div>
                                </div>

                                <div class="d-flex gap-2">
                                    <button type="submit" class="btn btn-primary flex-grow-1">
              <i class="bi bi-check-circle me-1"></i>Thêm Sản Phẩm
            </button>
                                    <a href="/products" class="btn btn-outline-secondary">
                                        <i class="bi bi-arrow-left me-1"></i>Hủy
                                    </a>
                                </div>
                            </form>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Live image preview
        document.getElementById('image').addEventListener('change', function() {
            const file = this.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = (e) => {
                document.getElementById('imgPreview').src = e.target.result;
                document.getElementById('imgPreviewBox').classList.remove('d-none');
            };
            reader.readAsDataURL(file);
        });

        // Client-side validation
        document.getElementById('addForm').addEventListener('submit', function(e) {
            let ok = true;
            const mark = (id, valid) => {
                document.getElementById(id).classList.toggle('is-invalid', !valid);
                if (!valid) ok = false;
            };

            mark('name', !!document.getElementById('name').value.trim());
            const price = parseFloat(document.getElementById('price').value);
            mark('price', !isNaN(price) && price > 0);
            const qty = parseInt(document.getElementById('quantity').value, 10);
            mark('quantity', !isNaN(qty) && qty >= 0);

            if (!ok) e.preventDefault();
        });
    </script>

    <%- include('partials/footer') %>